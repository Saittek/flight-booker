# Amadeus API credentials — free at https://developers.amadeus.com/register
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# "test" uses test.api.amadeus.com (sandbox bookings, no real charges)
# "production" for live bookings (requires Amadeus production access)
AMADEUS_HOSTNAME=test

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: for Stripe webhooks (required for secure production checkout)
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudflare Workers (set in dashboard secrets + build env, or copy to .dev.vars for preview)
# Requires wrangler.jsonc bindings: BOOKINGS_KV, DB (D1)
# Run: npm run d1:migrate after creating D1 database
